# Newsbot environment variables
# Copy to .env and fill in your values

# Firecrawl (required for article extraction)
FIRECRAWL_API_KEY=your_firecrawl_key_here

# Email / SMTP (required for sending briefings)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=briefing-bot@example.com
SMTP_PASS=your_smtp_password

# OpenAI (required for LLM evaluation and summarization)
OPENAI_API_KEY=your_openai_key_here

# Output directory (optional - defaults to ./outputs)
# BRIEFING_OUTPUT_DIR=/Users/cyrusanderson/hermes-newsbot/outputs